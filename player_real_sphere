extends Node3D

var xangle: float
var yangle: float
var ground: Node3D

func positionalize():	
	var top = Vector3(0,
	 	ground.transform.origin.y 
		+ ground.transform.basis.get_scale().y / 2
		+ 1, 0
	)
	transform.origin = top.rotated(Vector3.LEFT, deg_to_rad(xangle))
	transform.basis = Basis.from_euler(Vector3(-deg_to_rad(xangle), 0, 0))
	print(transform.origin.z)
func _ready():
	ground = get_node("../Ground")
	xangle = 0
	yangle = 0
	positionalize()
	print(transform.origin.y)

func _process(_delta):
	pass
func _physics_process(_delta):
	xangle += 0.1
	positionalize()
